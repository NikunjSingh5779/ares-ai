# =============================================================================
# ARES AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database (PostgreSQL 16+) ---
POSTGRES_USER=ares
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=ares_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- ChromaDB ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=ares_memories

# --- OpenRouter (primary LLM provider) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenCode (LLM fallback provider) ---
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.opencode.ai/v1

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_SECRET_KEY=changeme_in_production
API_RATE_LIMIT_PER_MINUTE=100
API_CORS_ORIGINS=http://localhost:3000

# --- Trading ---
PAPER_TRADING_INITIAL_CAPITAL=100000.0
KILL_SWITCH_ENABLED=true
DEFAULT_TRADING_MODE=human_approval
MAX_POSITION_SIZE_PCT=5.0
MAX_DRAWDOWN_PCT=20.0

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Exchange: Coinbase ---
COINBASE_API_KEY=
COINBASE_SECRET_KEY=

# --- Exchange: Kraken ---
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
HEALTH_CHECK_INTERVAL_SECONDS=30
